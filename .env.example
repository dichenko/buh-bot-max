# MAX bot
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_API_TIMEOUT_SECONDS=30
MAX_API_RETRIES=5
MAX_API_RETRY_DELAY_SECONDS=2
MAX_ATTACHMENT_READY_RETRY_DELAY_SECONDS=1
BOT_SUBDOMAIN=https://bot.example.com
BOT_PORT=3003
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
ADMIN_IDS=111111111,222222222
BOT_TIMEZONE=Europe/Moscow
WORK_START=00:01
WORK_END=20:59
REQUEST_COOLDOWN_MINUTES=30
MAX_REQUEST_COUNT=5000

# PostgreSQL
POSTGRES_DB=buh_bot
POSTGRES_USER=buh_bot
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://buh_bot:change_me@postgres:5432/buh_bot

# pgAdmin
PGADMIN_SUBDOMAIN=pgadmin.example.com
PGADMIN_PORT=5051
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# MegaPlan
TOKEN_MEGAPLAN=
URL_MEGAPLAN=
MEGAPLAN_RESPONSIBLE_ID=1000038
MEGAPLAN_AUDITOR_IDS=1000003,1000019,1000038
MEGAPLAN_DEADLINE_DAYS=14

# Mail
# Comma-separated list. Example: ADMIN_EMAIL=ops@company.com,ceo@company.com
ADMIN_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Worker queue
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_IDLE_LOG_INTERVAL_SECONDS=60
WORKER_TEMPLATES_DIR=/app/templates
WORKER_OUTPUT_DIR=/app/obrazec
